.claude/settings.local.json

# design handoff export (raw scaffold/reference material, not app source)
/Identidade visual consistente-handoff/
/Identidade visual consistente-handoff.zip

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

*storybook.log
storybook-static
